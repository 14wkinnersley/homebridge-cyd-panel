# secrets.yaml.example
#
# The normal SmartDisplay firmware needs NO secrets. Wi-Fi is entered in the
# browser while flashing (Improv), and there is no Home Assistant API key or OTA
# password baked in. You can flash from the website and never create this file.
#
# This template only matters for the OPTIONAL, advanced link-test tool
# (esphome/homebridge/link-test.yaml), which logs in to Homebridge directly to
# validate the ESP32 <-> Homebridge round-trip on your hardware. If you use it,
# copy this file to secrets.yaml (gitignored) and fill in the two values below.

# Homebridge UI login used by link-test.yaml to obtain a bearer token.
# Not needed if you set link-test's HB_AUTH to "none" (Homebridge UI auth off).
hb_username: "admin"
hb_password: "your_homebridge_ui_password"
