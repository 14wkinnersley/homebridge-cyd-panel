# secrets.yaml.example
# Copy this file to secrets.yaml and fill in your actual values.
# secrets.yaml is gitignored and never committed.

wifi_ssid: "Your WiFi Network Name"
wifi_password: "your_wifi_password"

# Generate a random 32-byte base64 key, e.g.:
#   python3 -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
smartdisplay_api_key: "your_32_byte_base64_api_key_here="

# Any string works as OTA password
ota_password: "your_ota_password"

# Password for the fallback hotspot (shown when WiFi is unavailable)
wifi_ap_password: "your_fallback_password"

# ============================================================
# Homebridge integration (MQTT-free, via the Homebridge UI REST API)
# Only needed for the Homebridge configs — see esphome/HOMEBRIDGE.md.
#
# NOTE: your Homebridge URL is NOT here. Because ESPHome has to join it with
# "/api/..." paths at compile time (and !secret values can't be concatenated),
# the base URL lives in the config's HB_BASE_URL substitution instead. Keep the
# committed placeholder and set your real LAN URL only in your local copy.
# ============================================================

# Homebridge UI login used to obtain a bearer token.
# Not needed if you set the panel's HB_AUTH substitution to "none"
# (Homebridge UI authentication disabled — see the guide).
hb_username: "admin"
hb_password: "your_homebridge_ui_password"
